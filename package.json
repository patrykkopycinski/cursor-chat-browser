{
  "name": "cursor-chat-browser",
  "version": "0.0.1",
  "description": "MCP server that indexes and searches past Cursor conversations across all workspaces",
  "license": "Elastic-2.0",
  "author": "Patryk Kopycinski",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patrykkopycinski/cursor-chat-browser.git"
  },
  "homepage": "https://github.com/patrykkopycinski/cursor-chat-browser#readme",
  "bugs": {
    "url": "https://github.com/patrykkopycinski/cursor-chat-browser/issues"
  },
  "keywords": [
    "cursor",
    "mcp",
    "model-context-protocol",
    "conversation-search",
    "ai-assistant",
    "chat-history",
    "full-text-search"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cursor-chat-browser": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.0",
    "sql.js": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/sql.js": "^1.4.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
